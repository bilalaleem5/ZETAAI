# ============================================================
#  ZETA AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file to version control.

# ── Core AI Models (at least one required) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get free at: https://aistudio.google.com/app/apikey

GROQ_API_KEY=your_groq_api_key_here
# Get free at: https://console.groq.com

# ── Web Intelligence ────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
# Get free at: https://tavily.com (optional — falls back to DuckDuckGo)

# ── Weather (optional — falls back to wttr.in, no key needed) ──
OPENWEATHER_API_KEY=your_openweather_api_key_here
# Get free at: https://openweathermap.org/api

# ── News (optional — falls back to BBC RSS, no key needed) ──
GNEWS_API_KEY=your_gnews_api_key_here
# Get free at: https://gnews.io

# ── Integrations ────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here

# ── App Config ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
